        body {
            font-family: 'Gilroy', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background-color: #000000;
            color: #ffffff;
            line-height: 1.7;
        }

        /* HEADER - matches index */
        header {
            background-color: #000000;
            padding: 20px;
            position: sticky;
            top: 0;
            z-index: 100;
            transition: padding 0.3s ease;
        }

        header.scrolled {
            padding: 12px 20px;
        }

        .logo-container {
            max-width: 1200px;
            margin: 0 auto;
            text-align: center;
        }

        .logo {
            width: 140px;
            max-width: 40vw;
            height: auto;
            display: inline-block;
            transition: width 0.3s ease;
        }

        @media (min-width: 768px) {
            .logo {
                width: 200px;
            }
        }

        header.scrolled .logo {
            width: 90px;
        }

        @media (min-width: 768px) {
            header.scrolled .logo {
                width: 120px;
            }
        }

        /* CONTENT */
        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 60px 24px 80px;
        }

        .page-title {
            font-size: 40px;
            font-weight: 700;
            margin-bottom: 12px;
            letter-spacing: -1px;
        }

        .last-updated {
            font-size: 14px;
            color: #888888;
            margin-bottom: 48px;
        }

        h2 {
            font-size: 22px;
            font-weight: 700;
            color: #00A9CE;
            margin-top: 40px;
            margin-bottom: 16px;
        }

        p {
            font-size: 16px;
            color: #dddddd;
            margin-bottom: 16px;
        }

        a {
            color: #00A9CE;
            text-decoration: none;
        }

        a:hover {
            color: #FDDA25;
        }

        .back-link {
            display: inline-block;
            margin-bottom: 40px;
            color: #00A9CE;
            font-size: 14px;
            font-weight: 600;
        }

        .back-link:hover {
            color: #FDDA25;
        }

        /* FOOTER - matches index */
        footer {
            background-color: #0a0a0a;
            padding: 60px 20px;
        }

        .footer-content {
            max-width: 600px;
            margin: 0 auto;
            text-align: center;
        }

        .footer-links {
            display: flex;
            justify-content: center;
            gap: 24px;
            flex-direction: column;
            margin-bottom: 32px;
            font-size: 13px;
        }

        @media (min-width: 480px) {
            .footer-links {
                flex-direction: row;
                gap: 32px;
            }
        }

        .footer-links a {
            color: #00A9CE;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .footer-links a:hover {
            color: #FDDA25;
        }

        .footer-divider {
            height: 1px;
            background-color: transparent;
            margin: 24px 0;
        }

        .footer-info {
            font-size: 13px;
            color: #888888;
            margin-bottom: 24px;
            line-height: 1.8;
        }

        .footer-info p {
            margin-bottom: 6px;
        }

        @media (max-width: 600px) {
            .page-title {
                font-size: 30px;
            }
            .container {
                padding: 40px 20px 60px;
            }
        }
